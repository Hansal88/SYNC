# =====================================================
# PHONE OTP VERIFICATION - ENVIRONMENT VARIABLES
# =====================================================
# Copy this to your .env file and fill in your values

# ✅ TWILIO CONFIGURATION (REQUIRED FOR SMS)
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# ℹ️ HOW TO GET TWILIO CREDENTIALS:
# 1. Sign up at https://www.twilio.com/console
# 2. Copy Account SID from console
# 3. Copy Auth Token from console
# 4. Buy or verify a phone number for SMS
# 5. Add credentials below

# ✅ DATABASE CONFIGURATION
MONGODB_URI=mongodb://localhost:27017/skillexchange

# ✅ JWT CONFIGURATION
JWT_SECRET=your_very_secret_key_change_this_in_production

# ✅ SERVER CONFIGURATION
NODE_ENV=development
PORT=5000

# ✅ EMAIL CONFIGURATION (Existing)
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password

# ✅ CORS CONFIGURATION
CORS_ORIGIN=http://localhost:5173

# =====================================================
# NOTES:
# - Never commit this file to git
# - Use different credentials for dev/prod
# - Keep .env in .gitignore
# - In development, NODE_ENV=development shows OTP in responses
# - In production, NODE_ENV=production hides OTP from responses
# =====================================================

# TEST CREDENTIALS (Optional - For Twilio Testing)
# Account SID: ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Auth Token: your_auth_token
# Test Phone: +15005550001 (for testing)
